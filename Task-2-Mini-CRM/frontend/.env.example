# Leave blank / unset for local dev — Vite's dev server proxy (see vite.config.js)
# already forwards /api to http://localhost:5000.
#
# For production (e.g. deploying this frontend on Vercel), set this to your
# deployed backend's full URL, including the /api path:
#   VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=
